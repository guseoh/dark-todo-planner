# Local development
DATABASE_URL="file:../data/dev.db"
CLIENT_URL="http://localhost:5173"
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
JSON_BODY_LIMIT="2mb"
BACKUP_JSON_BODY_LIMIT="4mb"

# Optional in local development. Required for Docker/production unless
# ALLOW_INSECURE_PUBLIC_ACCESS=true is set intentionally.
APP_AUTH_ENABLED=false
APP_AUTH_USERNAME="todo"
APP_AUTH_PASSWORD=""
ALLOW_INSECURE_PUBLIC_ACCESS=false

# Docker / production example
# DOCKER_DATABASE_URL="file:../data/prod.db"
# PORT=3000
# HOST=0.0.0.0
# NODE_ENV=production
# APP_AUTH_ENABLED=true
# APP_AUTH_USERNAME="todo"
# APP_AUTH_PASSWORD="replace-with-a-long-random-password"

# Optional: only needed when the frontend calls an API server on a different origin.
# In the default dev setup Vite proxies /api to Express, so this can stay empty.
# VITE_API_BASE_URL="http://localhost:3000"

# GitHub Pages static preview build only.
# GITHUB_PAGES=true
