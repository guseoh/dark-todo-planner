{
  "name": "dark-todo-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev --local",
    "build": "tsc -b && vite build && wrangler deploy --dry-run --env=\"\" --outdir .wrangler/build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "preview": "npm run build && wrangler dev --env preview --remote",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:preview": "wrangler d1 migrations apply DB --env preview --remote",
    "db:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
    "auth:hash": "node scripts/hash-password.mjs",
    "deploy:preview": "npm run build && wrangler deploy --env preview",
    "deploy:production": "npm run build && wrangler deploy --env production"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
